<%- include('layout/header', { title: 'Home' }) %>
<%- include('layout/nav') %>

<main class="container page-container">
  <% if (error) { %>
    <p class="form-error"><%= error %></p>
  <% } %>

  <% if (currentUser && engagement) { %>
    <section class="panel engagement-panel">
      <div class="engagement-panel-head">
        <div>
          <h2>Your Streak</h2>
          <p class="muted"><strong><%= engagement.streak.current %> day<%= engagement.streak.current === 1 ? '' : 's' %></strong> active streak · best <strong><%= engagement.streak.best %></strong></p>
        </div>
        <a href="/users/<%= currentUser.username %>" class="btn-secondary engagement-link">View profile</a>
      </div>

      <% if (engagement.nextAchievement) { %>
        <p class="engagement-next">
          Next achievement: <strong><%= engagement.nextAchievement.title %></strong>
          (<%= engagement.nextAchievement.current %>/<%= engagement.nextAchievement.target %>)
        </p>
      <% } %>
    </section>
  <% } %>

  <% if (currentUser) { %>
    <section class="compose-box">
      <form method="POST" action="/tweets" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label for="tweet-content" class="sr-only">What is happening?</label>
        <textarea id="tweet-content" name="content" class="tweet-textarea" maxlength="280" required placeholder="What is happening?"></textarea>
        <label for="tweet-image" class="media-label">Attach image (optional)</label>
        <input
          id="tweet-image"
          name="image"
          type="file"
          accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
          class="media-input"
        >
        <p class="upload-help">JPG, PNG, or WebP up to 5 MB.</p>
        <p class="form-error upload-error" data-upload-error aria-live="polite" hidden></p>
        <div class="compose-footer">
          <span class="char-counter">280</span>
          <button type="submit" class="btn-primary">Post</button>
        </div>
      </form>
    </section>
  <% } %>

  <section>
    <% if (!tweets.length) { %>
      <p class="muted">No tweets yet. Follow people or post your first tweet.</p>
    <% } %>

    <% tweets.forEach((tweet) => { %>
      <%- include('partials/tweet-card', { tweet: tweet }) %>
    <% }) %>
  </section>
</main>

<%- include('layout/footer') %>
