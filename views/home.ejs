<%- include('layout/header', { title: 'Home' }) %>
<%- include('layout/nav') %>

<main class="container page-container">
  <% if (error) { %>
    <p class="form-error"><%= error %></p>
  <% } %>

  <% if (currentUser) { %>
    <section class="compose-box">
      <form method="POST" action="/tweets">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label for="tweet-content" class="sr-only">What is happening?</label>
        <textarea id="tweet-content" name="content" class="tweet-textarea" maxlength="280" required placeholder="What is happening?"></textarea>
        <div class="compose-footer">
          <span class="char-counter">280</span>
          <button type="submit" class="btn-primary">Post</button>
        </div>
      </form>
    </section>
  <% } %>

  <section>
    <% if (!tweets.length) { %>
      <p class="muted">No tweets yet. Follow people or post your first tweet.</p>
    <% } %>

    <% tweets.forEach((tweet) => { %>
      <%- include('partials/tweet-card', { tweet: tweet }) %>
    <% }) %>
  </section>
</main>

<script src="/public/js/app.js"></script>
</body>
</html>
