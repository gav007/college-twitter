<% const unreadCount = notificationUnreadCount || 0; %>
<nav class="site-nav" role="navigation" aria-label="Main navigation">
  <div class="nav-bar">
    <a href="/" class="nav-logo">Loopfeed</a>

    <div class="nav-actions-right">
      <a href="/explore" class="nav-link nav-priority-link">Explore</a>
      <% if (currentUser) { %>
        <a href="/users/<%= currentUser.username %>" class="nav-avatar-link nav-priority-link" aria-label="Open profile">
          <% if (currentUser.avatar_url) { %>
            <img src="<%= currentUser.avatar_url %>" alt="<%= currentUser.display_name %> avatar" class="nav-avatar-image">
          <% } else { %>
            <span class="nav-avatar-fallback"><%= (currentUser.display_name || currentUser.username).slice(0, 1).toUpperCase() %></span>
          <% } %>
        </a>
        <a href="/notifications" class="nav-link nav-priority-link">Notifications</a>
        <button
          class="btn-post-global"
          data-open-compose
          aria-label="Compose"
          type="button"
        >
          <span aria-hidden="true">✦ Post</span>
        </button>
      <% } else { %>
        <button type="button" id="theme-toggle" class="nav-link nav-toggle-theme nav-priority-link">Theme</button>
        <a href="/login" class="nav-link nav-priority-link">Login</a>
        <a href="/register" class="nav-link nav-priority-link">Register</a>
      <% } %>

      <button
        class="nav-hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
        type="button"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <ul class="nav-menu" id="nav-menu" role="list">
    <% if (currentUser) { %>
      <li><a href="/" class="nav-link">Home</a></li>
      <li><a href="/users/<%= currentUser.username %>" class="nav-link">Profile</a></li>
      <li><button type="button" id="theme-toggle" class="nav-link nav-toggle-theme">Theme</button></li>
      <li>
        <form method="POST" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="nav-link nav-logout">Logout</button>
        </form>
      </li>
    <% } %>
  </ul>
</nav>
