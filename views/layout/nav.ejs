<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand">Loopfeed</a>
    <div class="nav-links">
      <a href="/explore">Explore</a>
      <button type="button" id="theme-toggle" class="link-btn theme-toggle" aria-label="Toggle theme">
        Theme
      </button>
      <% if (currentUser) { %>
        <a href="/users/<%= currentUser.username %>">@<%= currentUser.username %></a>
        <form method="POST" action="/logout" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="link-btn">Logout</button>
        </form>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register">Register</a>
      <% } %>
    </div>
  </div>
</nav>
