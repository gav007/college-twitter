<% const unreadCount = notificationUnreadCount || 0; %>
<nav class="site-nav" role="navigation" aria-label="Main navigation">
  <div class="nav-bar">
    <a href="/" class="nav-logo">Loopfeed</a>

    <div class="nav-actions-right">
      <% if (currentUser) { %>
        <button
          class="btn-post-global"
          onclick="document.getElementById('global-compose-modal').showModal()"
          aria-label="Compose"
          type="button"
        >
          <span aria-hidden="true">✦ Post</span>
        </button>
      <% } %>

      <% if (currentUser && unreadCount > 0) { %>
        <a href="/notifications" class="nav-notif-badge" aria-label="<%= unreadCount %> unread notifications">
          <span class="badge"><%= unreadCount %></span>
        </a>
      <% } %>

      <button
        class="nav-hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
        type="button"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <ul class="nav-menu" id="nav-menu" role="list">
    <li><a href="/" class="nav-link">Home</a></li>
    <li><a href="/explore" class="nav-link">Explore</a></li>
    <li>
      <button type="button" id="theme-toggle" class="nav-link nav-toggle-theme">Theme</button>
    </li>
    <% if (currentUser) { %>
      <li><a href="/users/<%= currentUser.username %>" class="nav-link">Profile</a></li>
      <li><a href="/notifications" class="nav-link">Notifications</a></li>
      <li>
        <form method="POST" action="/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="nav-link nav-logout">Logout</button>
        </form>
      </li>
    <% } else { %>
      <li><a href="/login" class="nav-link">Login</a></li>
      <li><a href="/register" class="nav-link">Register</a></li>
    <% } %>
  </ul>
</nav>
