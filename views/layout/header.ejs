<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Loopfeed</title>
  <meta name="application-name" content="Loopfeed">
  <meta name="apple-mobile-web-app-title" content="Loopfeed">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="theme-color" content="#3b5998">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="icon" type="image/svg+xml" href="/public/favicon.svg">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/public/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/public/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/main.css">
</head>
<body>
<% if (currentUser) { %>
<dialog id="global-compose-modal" class="compose-modal" aria-label="New post">
  <div class="compose-modal-inner">
    <div class="compose-modal-header">
      <span class="compose-modal-title">New Post</span>
      <button class="compose-modal-close" data-close-compose aria-label="Close" type="button">✕</button>
    </div>
    <form method="POST" action="/tweets?source=modal" class="compose-form-modal" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <textarea
        name="content"
        class="tweet-textarea"
        placeholder="What's happening?"
        maxlength="280"
        rows="4"
        autofocus
        required
      ></textarea>
      <div class="compose-footer">
        <span class="char-counter">280</span>
        <label class="file-upload-label file-upload-label-wide" aria-label="Attach image">
          <span class="file-upload-icon" aria-hidden="true">📎</span>
          <span>Attach image</span>
          <input
            type="file"
            name="image"
            accept="image/jpeg,image/png,image/webp"
            class="file-input-hidden"
            data-file-name-output="#modal-image-file-name"
          >
        </label>
        <span id="modal-image-file-name" class="file-name-text">No file selected</span>
        <button type="submit" class="btn-primary">Post</button>
      </div>
      <p class="upload-help">JPG, PNG, or WebP up to 5 MB.</p>
      <p class="form-error upload-error" data-upload-error aria-live="polite" hidden></p>
    </form>
  </div>
</dialog>
<% } %>
