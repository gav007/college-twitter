<%- include('layout/header', { title: profileUser.display_name }) %>
<%- include('layout/nav') %>

<main class="container page-container profile-page">
  <section class="panel profile-shell">
    <div class="profile-banner"></div>
    <div class="profile-avatar">
      <% if (profileUser.avatar_url) { %>
        <img src="<%= safeImageUrl(profileUser.avatar_url) %>" alt="<%= profileUser.display_name %> avatar" class="profile-avatar-image">
      <% } else { %>
        <span><%= (profileUser.display_name || profileUser.username).slice(0, 1).toUpperCase() %></span>
      <% } %>
    </div>

    <div class="profile-headline">
      <h1><%= profileUser.display_name %></h1>
      <p class="tweet-username">@<%= profileUser.username %></p>
      <% if (profileUser.is_bot) { %>
        <p class="bot-profile-note">Automated account</p>
      <% } %>
      <% if (profileUser.is_private) { %>
        <p class="private-account-note">🔒 Private account</p>
      <% } else { %>
        <p class="private-account-note">🌐 Public account</p>
      <% } %>
      <p class="profile-joined">Joined <%= joinedDate %></p>
    </div>

    <% if (profileUser.bio) { %>
      <p class="profile-bio"><%= profileUser.bio %></p>
    <% } %>

    <div class="profile-metrics">
      <a class="profile-metric-card" href="/users/<%= profileUser.username %>#profile-posts">
        <span class="metric-value"><%= formatCount(tweetCount) %></span>
        <span class="metric-label">Posts</span>
      </a>
      <a class="profile-metric-card" href="/users/<%= profileUser.username %>/followers">
        <span class="metric-value"><%= formatCount(followerCount) %></span>
        <span class="metric-label">Followers</span>
      </a>
      <a class="profile-metric-card" href="/users/<%= profileUser.username %>/following">
        <span class="metric-value"><%= formatCount(followingCount) %></span>
        <span class="metric-label">Following</span>
      </a>
    </div>

    <% if (profileEngagement) { %>
      <section class="profile-progress">
        <div class="profile-streak-row">
          <span class="progress-chip">🔥 <strong><%= profileEngagement.streak.current %></strong> day streak</span>
          <span class="progress-chip">🏆 Best <strong><%= profileEngagement.streak.best %></strong></span>
        </div>

        <h2>Achievements</h2>
        <% if (!profileEngagement.unlockedAchievements.length) { %>
          <p class="muted">No achievements unlocked yet.</p>
        <% } else { %>
          <div class="achievement-grid">
            <% profileEngagement.unlockedAchievements.forEach((achievement) => { %>
              <article class="achievement-card">
                <p class="achievement-icon"><%= achievement.icon %></p>
                <p class="achievement-title"><%= achievement.title %></p>
                <p class="achievement-description"><%= achievement.description %></p>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (currentUser && currentUser.id !== profileUser.id) { %>
      <div class="profile-actions">
        <form method="POST" action="/users/<%= profileUser.username %>/follow">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-primary">
            <% if (isFollowing) { %>
              Unfollow
            <% } else if (profileUser.is_private) { %>
              <%= hasPendingRequest ? 'Cancel request' : 'Request follow' %>
            <% } else { %>
              Follow
            <% } %>
          </button>
        </form>
        <form method="POST" action="/messages/start/<%= profileUser.username %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-secondary">Message</button>
        </form>
        <form method="POST" action="/pokes/<%= profileUser.username %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-secondary">Poke</button>
        </form>

        <% if (isFollowing) { %>
          <form method="POST" action="/users/<%= profileUser.username %>/notify">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-secondary">
              Notify Posts: <%= notifyPostsEnabled ? 'On' : 'Off' %>
            </button>
          </form>
        <% } %>
      </div>
    <% } %>

    <% if (currentUser && currentUser.id === profileUser.id) { %>
      <section class="profile-edit-panel">
        <h2>Edit Profile</h2>
        <p class="muted">Update how your profile appears. Changing username updates your profile URL.</p>

        <% if (profileUpdated) { %>
          <p class="form-success">Profile updated.</p>
        <% } %>
        <% if (profileError) { %>
          <p class="form-error"><%= profileError %></p>
        <% } %>

        <form method="POST" action="/settings/avatar" class="auth-form avatar-upload-form" enctype="multipart/form-data">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <label for="profile-avatar-image">Avatar image</label>
          <div class="media-picker-row">
            <label class="file-upload-label file-upload-label-wide" for="profile-avatar-image">
              <span class="file-upload-icon" aria-hidden="true">📷</span>
              <span>Choose image</span>
            </label>
            <span id="profile-avatar-file-name" class="file-name-text">No file selected</span>
          </div>
          <input
            id="profile-avatar-image"
            name="avatar_image"
            type="file"
            accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
            class="file-input-hidden"
            data-file-name-output="#profile-avatar-file-name"
          >
          <p class="muted">Upload JPG, PNG, or WebP. Drag to position and use zoom, max 1 MB.</p>

          <div class="avatar-cropper" hidden data-avatar-cropper>
            <div class="avatar-cropper-stage" data-avatar-cropper-stage>
              <img alt="Avatar crop preview" class="avatar-cropper-image" data-avatar-cropper-image>
            </div>
            <label for="avatar-zoom-range">Zoom</label>
            <input id="avatar-zoom-range" type="range" min="1" max="3" step="0.01" value="1" data-avatar-zoom>
            <p class="muted">Move the image with mouse or finger to frame your avatar.</p>
          </div>

          <p class="form-error" hidden data-avatar-upload-error></p>

          <button type="submit" class="btn-primary">Upload Avatar</button>
        </form>

        <form method="POST" action="/settings/profile" class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <label for="profile-username">Username</label>
          <input
            id="profile-username"
            name="username"
            type="text"
            maxlength="20"
            required
            value="<%= editForm.username %>"
          >

          <label for="profile-display-name">Display Name</label>
          <input
            id="profile-display-name"
            name="display_name"
            type="text"
            maxlength="50"
            required
            value="<%= editForm.display_name %>"
          >

          <label for="profile-bio">Bio</label>
          <textarea
            id="profile-bio"
            name="bio"
            rows="3"
            maxlength="160"
            placeholder="Write a short bio"
          ><%= editForm.bio %></textarea>

          <label for="profile-avatar-url">Avatar URL</label>
          <input
            id="profile-avatar-url"
            name="avatar_url"
            type="url"
            maxlength="300"
            placeholder="https://example.com/avatar.jpg"
            value="<%= editForm.avatar_url %>"
          >
          <p class="muted">Optional: use an external image URL instead of an uploaded avatar.</p>

          <label class="visibility-toggle" for="profile-private-toggle">
            <span class="visibility-toggle-copy">
              <strong>Private account</strong>
              <small>Only followers can view your posts and follow list.</small>
            </span>
            <input
              id="profile-private-toggle"
              name="is_private"
              type="checkbox"
              value="1"
              <%= editForm.is_private ? 'checked' : '' %>
            >
            <span class="visibility-toggle-switch" aria-hidden="true"></span>
          </label>

          <button type="submit" class="btn-primary">Save Profile</button>
        </form>
      </section>
    <% } %>
  </section>

  <section class="profile-posts" id="profile-posts">
    <h2>Posts</h2>
    <% if (!canViewPosts) { %>
      <p class="muted">This account is private. Follow to see posts.</p>
    <% } else if (!tweets.length) { %>
      <p class="muted">No tweets yet.</p>
    <% } %>

    <% if (canViewPosts) { %>
      <% tweets.forEach((tweet) => { %>
        <%- include('partials/tweet-card', { tweet: tweet }) %>
      <% }) %>
    <% } %>
  </section>
</main>

<%- include('layout/footer') %>
