<%- include('layout/header', { title: profileUser.display_name }) %>
<%- include('layout/nav') %>

<main class="container page-container profile-page">
  <section class="panel profile-shell">
    <div class="profile-banner"></div>
    <div class="profile-avatar">
      <% if (profileUser.avatar_url) { %>
        <img src="<%= profileUser.avatar_url %>" alt="<%= profileUser.display_name %> avatar" class="profile-avatar-image">
      <% } else { %>
        <span><%= (profileUser.display_name || profileUser.username).slice(0, 1).toUpperCase() %></span>
      <% } %>
    </div>

    <div class="profile-headline">
      <h1><%= profileUser.display_name %></h1>
      <p class="tweet-username">@<%= profileUser.username %></p>
      <p class="profile-joined">Joined <%= joinedDate %></p>
    </div>

    <% if (profileUser.bio) { %>
      <p class="profile-bio"><%= profileUser.bio %></p>
    <% } %>

    <div class="profile-metrics">
      <article class="profile-metric-card">
        <span class="metric-value"><%= tweetCount %></span>
        <span class="metric-label">Posts</span>
      </article>
      <article class="profile-metric-card">
        <span class="metric-value"><%= followerCount %></span>
        <span class="metric-label">Followers</span>
      </article>
      <article class="profile-metric-card">
        <span class="metric-value"><%= followingCount %></span>
        <span class="metric-label">Following</span>
      </article>
    </div>

    <% if (profileEngagement) { %>
      <section class="profile-progress">
        <div class="profile-streak-row">
          <span class="progress-chip">🔥 <strong><%= profileEngagement.streak.current %></strong> day streak</span>
          <span class="progress-chip">🏆 Best <strong><%= profileEngagement.streak.best %></strong></span>
        </div>

        <h2>Achievements</h2>
        <% if (!profileEngagement.unlockedAchievements.length) { %>
          <p class="muted">No achievements unlocked yet.</p>
        <% } else { %>
          <div class="achievement-grid">
            <% profileEngagement.unlockedAchievements.forEach((achievement) => { %>
              <article class="achievement-card">
                <p class="achievement-icon"><%= achievement.icon %></p>
                <p class="achievement-title"><%= achievement.title %></p>
                <p class="achievement-description"><%= achievement.description %></p>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
    <% } %>

    <% if (currentUser && currentUser.id !== profileUser.id) { %>
      <div class="profile-actions">
        <form method="POST" action="/users/<%= profileUser.username %>/follow">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-primary"><%= isFollowing ? 'Unfollow' : 'Follow' %></button>
        </form>

        <% if (isFollowing) { %>
          <form method="POST" action="/users/<%= profileUser.username %>/notify">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-secondary">
              Notify Posts: <%= notifyPostsEnabled ? 'On' : 'Off' %>
            </button>
          </form>
        <% } %>
      </div>
    <% } %>

    <% if (currentUser && currentUser.id === profileUser.id) { %>
      <section class="profile-edit-panel">
        <h2>Edit Profile</h2>
        <p class="muted">Update how your profile appears. Changing username updates your profile URL.</p>

        <% if (profileUpdated) { %>
          <p class="form-success">Profile updated.</p>
        <% } %>
        <% if (profileError) { %>
          <p class="form-error"><%= profileError %></p>
        <% } %>

        <form method="POST" action="/settings/profile" class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <label for="profile-username">Username</label>
          <input
            id="profile-username"
            name="username"
            type="text"
            maxlength="20"
            required
            value="<%= editForm.username %>"
          >

          <label for="profile-display-name">Display Name</label>
          <input
            id="profile-display-name"
            name="display_name"
            type="text"
            maxlength="50"
            required
            value="<%= editForm.display_name %>"
          >

          <label for="profile-bio">Bio</label>
          <textarea
            id="profile-bio"
            name="bio"
            rows="3"
            maxlength="160"
            placeholder="Write a short bio"
          ><%= editForm.bio %></textarea>

          <label for="profile-avatar-url">Avatar URL</label>
          <input
            id="profile-avatar-url"
            name="avatar_url"
            type="url"
            maxlength="300"
            placeholder="https://example.com/avatar.jpg"
            value="<%= editForm.avatar_url %>"
          >

          <button type="submit" class="btn-primary">Save Profile</button>
        </form>
      </section>
    <% } %>
  </section>

  <section class="profile-posts">
    <h2>Posts</h2>
    <% if (!tweets.length) { %>
      <p class="muted">No tweets yet.</p>
    <% } %>

    <% tweets.forEach((tweet) => { %>
      <%- include('partials/tweet-card', { tweet: tweet }) %>
    <% }) %>
  </section>
</main>

<%- include('layout/footer') %>
