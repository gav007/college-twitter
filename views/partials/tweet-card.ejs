<article class="tweet-card" data-tweet-id="<%= tweet.id %>">
  <div class="tweet-header">
    <a href="/users/<%= tweet.username %>" class="tweet-author">
      <strong><%= tweet.display_name %></strong>
      <% if (tweet.is_bot) { %>
        <span class="bot-badge" aria-label="Automated account">Bot</span>
      <% } %>
      <span class="tweet-username">@<%= tweet.username %></span>
    </a>
    <time class="tweet-time"><%= formatTime(tweet.created_at) %></time>
  </div>

  <p class="tweet-content"><%= tweet.content %></p>
  <% if (tweet.media_id) { %>
    <div class="tweet-media">
      <img
        src="/media/<%= tweet.media_id %>"
        alt="Post image"
        class="tweet-image"
        loading="lazy"
      >
    </div>
    <p class="media-expiry-badge" aria-label="Image expires soon">
      <span class="expiry-icon">⏱</span> Image disappears in ~1h
    </p>
  <% } %>

  <div class="tweet-actions">
    <% if (currentUser) { %>
      <button class="like-btn <%= tweet.liked_by_me ? 'liked' : '' %>" data-tweet-id="<%= tweet.id %>" type="button">
        ♥ <span class="like-count"><%= tweet.like_count %></span>
      </button>
    <% } else { %>
      <span class="like-count-static">♥ <%= tweet.like_count %></span>
    <% } %>

    <a href="/tweets/<%= tweet.id %>" class="reply-link">Reply</a>
    <a href="/tweets/<%= tweet.id %>" class="reply-count-link">
      Replies <span class="reply-count"><%= tweet.reply_count || 0 %></span>
    </a>

    <% if (currentUser && currentUser.id === tweet.user_id) { %>
      <form method="POST" action="/tweets/<%= tweet.id %>/delete" class="delete-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="delete-btn">Delete</button>
      </form>
    <% } %>
  </div>
</article>
